					<a href="#traiteur" id="menu-link-ateliers" class="hover:text-white transition-colors">Ateliers</a>
				</nav>

				<div class="flex items-center gap-2 lg:gap-4">
					<div class="hidden sm:flex items-center border-r border-cat-pine/20 pr-4 mr-2 gap-3">
						<a href="https://www.instagram.com/catseyesjusetsoupesorleans/" target="_blank" class="text-cat-pine hover:text-white hover:scale-110 transition-all" aria-label="Instagram">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
						</a>
						<a href="https://www.facebook.com/Nfl45CatsEyes/" target="_blank" class="text-cat-pine hover:text-white hover:scale-110 transition-all" aria-label="Facebook">
