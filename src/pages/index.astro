	}
	</style>

	<script define:vars={{ slides }}>
		const carousel = document.getElementById('concept-carousel');
		const contentArea = document.getElementById('carousel-content');
		const swipeHint = document.getElementById('adn-swipe-hint');
		const slidesElements = carousel.querySelectorAll('[data-index]');
		
		let hasInteracted = false;
		let isFirstScroll = true; 
		let currentActiveIndex = "0"; // On garde en mémoire l'index affiché

		// 1. MISE À JOUR DU CONTENU
		function updateContent(index, animate = true) {
			const data = slides[index];
			const animationClass = animate ? 'animate-text-entrance' : '';
			
			contentArea.innerHTML = `
				<div class="text-center lg:text-left ${animationClass}">
					<h2 class="text-cat-teal font-black uppercase tracking-widest text-[11px] mb-4 italic">${data.subtitle}</h2>
					<h3 class="text-4xl md:text-6xl font-bold text-cat-pine italic leading-tight mb-8 text-balance">${data.title}</h3>
					
					<div class="adn-text-block p-8 md:p-12 rounded-tr-[4rem] rounded-bl-[3rem] border-2 shadow-xl -rotate-1 relative transition-all duration-500 cursor-default" 
						style="background-color: white; border-color: ${data.color};">
						
						<div class="absolute -top-6 -left-4 bg-white border-2 p-3 rounded-2xl shadow-lg rotate-12" style="border-color: ${data.color};">
							<img src="${data.icon}" class="w-10 h-10 object-contain" alt="icon" />
						</div>

						<p class="text-cat-pine/90 text-lg md:text-xl leading-relaxed italic font-medium">"${data.description}"</p>
						
						<div class="mt-8 flex items-center gap-4 text-cat-pine/40 font-bold text-[10px] uppercase tracking-[0.2em]">
							<span class="h-[1px] w-12" style="background-color: ${data.color};"></span>
							L'engagement Cat's Eyes
						</div>
					</div>
				</div>
			`;
		}

		// Initialisation statique
		updateContent(0, false);

		const hideHint = () => {
			if (!hasInteracted && swipeHint) {
				hasInteracted = true;
				swipeHint.classList.replace('opacity-100', 'opacity-0');
				setTimeout(() => swipeHint.remove(), 700);
			}
		};

		// 2. OBSERVER (Correction de la boucle d'animation)
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const index = entry.target.getAttribute('data-index');
					
					// CONDITION CRUCIALE : On n'anime QUE si l'index a changé
					// et que ce n'est pas le tout premier chargement de la page
					if (index !== currentActiveIndex && !isFirstScroll) {
						updateContent(index, true);
						currentActiveIndex = index; // On met à jour l'index actuel
					}
					
					if (isFirstScroll) {
						isFirstScroll = false;
						currentActiveIndex = index;
					}
					
					if (!hasInteracted && swipeHint) {
						swipeHint.classList.replace('opacity-0', 'opacity-100');
						setTimeout(hideHint, 2700);
					}
				}
			});
		}, { threshold: 0.7 });

		slidesElements.forEach(slide => observer.observe(slide));

		// 3. NAVIGATION
		carousel.addEventListener('scroll', () => {
			hideHint();
		}, { passive: true });

		document.getElementById('next-btn').onclick = () => {
			isFirstScroll = false;
			carousel.scrollBy({ left: carousel.offsetWidth, behavior: 'smooth' });
			hideHint();
		};
		document.getElementById('prev-btn').onclick = () => {
			isFirstScroll = false;
			carousel.scrollBy({ left: -carousel.offsetWidth, behavior: 'smooth' });
			hideHint();
		};
	</script>
	
