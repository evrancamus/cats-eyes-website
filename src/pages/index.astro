---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { supabase } from '../lib/supabase';

// 1. RÉCUPÉRATION DES DONNÉES EN PARALLÈLE (Plus rapide)
const [allProductsRaw, settingsRes, stocksRes] = await Promise.all([
    getCollection('menu'),
    supabase.from('settings').select('value').eq('key', 'vacation_mode').single(),
    supabase.from('stocks').select('product_slug, en_stock')
]);

// 2. GESTION DU MODE VACANCES
const isVacation = settingsRes.data?.value || false;

// 3. GESTION DES STOCKS (Plats et Ingrédients)
const stocksData = stocksRes.data || [];
const GLOBAL_STOCK_PREFIX = 'global:';

// Tableau des IDs de plats épuisés (ex: ["banh-cuon"])
const slugsEpuises = stocksData
    .filter(s => s.en_stock === false && !s.product_slug.startsWith(GLOBAL_STOCK_PREFIX))
    .map(s => s.product_slug);
const slugsEpuisesSet = new Set(slugsEpuises);

// Tableau des ingrédients globaux épuisés (nettoyés pour la comparaison)
const ingredientsEpuises = stocksData
    .filter(s => s.en_stock === false && s.product_slug.startsWith(GLOBAL_STOCK_PREFIX))
    .map(s => s.product_slug.split(':')[1].replace(/-/g, ' ').toLowerCase());
const ingredientsEpuisesSet = new Set(ingredientsEpuises);

// 4. TRI DES PRODUITS (Best Sellers en premier)
const allProducts = allProductsRaw.sort((a, b) => {
    const aBest = a.data.is_bestseller || false;
    const bBest = b.data.is_bestseller || false;

    if (aBest && !bBest) return -1;
    if (!aBest && bBest) return 1;
    return 0; // On garde l'ordre original pour le reste
});

// 5. GÉNÉRATION DYNAMIQUE DES CATÉGORIES
// On récupère toutes les catégories présentes dans les fichiers markdown/json
const dynamicCategories = [...new Set(allProducts.map(p => p.data.category))];
const dynamicCategoriesSet = new Set(dynamicCategories);

// On définit l'ordre souhaité (optionnel) et on filtre pour ne garder que ce qui existe
const order = ["Soupes", "Plats", "Desserts", "Hors d'œuvres"];
const availableCategories = order.filter(cat => dynamicCategoriesSet.has(cat));

// On ajoute "Tout" au début
const categories = ["Tout", ...availableCategories];

const restaurantName = "Cat's Eyes";

// 6. CONFIGURATION GÉNÉRALE
const slides = [
    {
        image: "/images/concept-1.webp",
        title: "Naly et son équipe pour vous servir !",
        subtitle: "L'ADN Cat's Eyes",
        icon: "/icons/sun-hand-drawn-irregular-shape.png",
        color: "#FFD700",
        description: "Toujours Souriante et bienveillante, Naly est propriétaire du restaurant depuis 2021, elle vous accueillera toutes les semaines entre Mardi et Samedi de 12h30 et 19h!"
    },
    {
        image: "/images/concept-2.webp",
        title: "100% frais, <br> 100% fait maison ! ",
        subtitle: "L'ADN Cat's Eyes",
        icon: "/icons/healthy.png",
        color: "#126b13",
        description: "Toutes nos recettes sont cuisinées minute, à partir d'ingrédients frais et de qualité.<br><br>Nos soupes et bouillons vous offrent une authenticité rare, chacun de nos plats est un voyage"
    },
    {
        image: "/images/concept-4.webp",
        title: "Propreté et soin impeccables !",
        subtitle: "L'ADN Cat's Eyes",
        icon: "/icons/health.png",
        color: "#388fa2",
        description: "Nous appliquons une rigueur intarissable concernant la propreté de nos espaces d'accueil.<br><br>Chacune de nos présentations est fignolée avec la plus grande attention !"
    },
    {
        image: "/images/concept-3.webp",
        title: "Un lieu vivant, et chaleureux !",
        subtitle: "L'ADN Cat's Eyes",
        icon: "/icons/soup-hand-drawn-hot-food-bowl.png",
        color: "#e472e0",
        description: "Musique, couleurs, douceur...<br>On se sent bien chez nous ! <br> <br>Nous avons travaillé chaque petit détail pour créer une atmosphère douce, et relaxante... Venez vous détendre et rencontrer Light, notre mascotte !"
    },
    {
        image: "/images/concept-5.webp",
        title: "Des instruments à disposition !",
        subtitle: "L'ADN Cat's Eyes",
        icon: "/icons/musical-note-hand-drawn-outline.png",
        color: "#FFD700",
        description: "Un piano tout jaune tout neuf, guitare et percussion à disposition... <br><br> Vous pouvez aussi amener vos propres instruments si vous voulez Jammer !"
    },
    {
        image: "/images/concept-6.webp",
        title: "Club d'échec en devenir !",
        subtitle: "L'ADN Cat's Eyes",
        icon: "/icons/strategy.png",
        color: "#388fa2",
        description: "Une bonne partie d'échecs... un jus pressé... ou une soupe... Ou les deux !"
    },
];
---

<Layout title="Accueil">
	
	<header class="bg-cat-yellow py-4 px-6 sticky top-0 z-50 shadow-md">
		<div class="max-w-7xl mx-auto flex justify-between items-center">
			<a href="/" class="flex items-center gap-3">
				<img src="images/CE-picto-nobackground.png" alt="Logo" class="h-10 w-10 border-cat-pine" />
				<div class="flex flex-col">
					<span class="font-black text-cat-pine leading-none text-xl">CAT'S EYES</span>
					<span class="text-[10px] font-bold text-cat-pine/70 uppercase tracking-tighter">Jus • Soupes • Traiteur</span>
				</div>
			</a>

			<div class="flex items-center gap-6">
				<nav id="menu-nav" class="hidden lg:flex items-center gap-8 font-bold text-cat-pine uppercase text-sm tracking-widest">
					<a href="#adn" class="hover:text-white hover:-translate-y-0.5 transition-all text-xs lg:text-sm">Notre ADN</a>
					<a href="#menu" class="hover:text-white hover:-translate-y-0.5 transition-all text-xs lg:text-sm">La Carte</a>
