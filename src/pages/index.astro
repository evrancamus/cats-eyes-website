												<p class="text-[9px] font-black uppercase text-cat-pine/40 tracking-widest italic">
													Intensité :
												</p>
												<span class="spice-level-text text-[10px] font-black uppercase italic">
													Pas de Piment 🌿
												</span>
											</div>
											
											<div class="relative flex items-center py-4">
												<input 
													type="range" 
													min="0" 
													max="3" 
													step="1" 
													value="0" 
													class="spice-range w-full h-1.5 bg-white border border-cat-pine/10 rounded-full appearance-none cursor-pointer"
												/>
											</div>
										</div>
									)}

									{/* FOOTER */}
									<div class="mt-auto pt-4 border-t border-dashed border-cat-pine/10 flex justify-between items-center gap-2">
										<div class="flex flex-col">
											{/* Preorder logic - Toujours conditionnel car lié au temps, pas au stock live */}
											{isPreorder && !isEpuise && (
												<div class="preorder-badge flex items-center gap-2 bg-cat-teal/10 border border-cat-teal/20 px-3 py-1.5 rounded-xl shadow-sm">
													<span class="animate-pulse text-xs">⏳</span>
													<div class="flex flex-col">
														<span class="text-[9px] font-black text-cat-teal uppercase leading-none">Sur Réservation</span>
														<span class="text-[8px] text-cat-teal/70 font-bold uppercase tracking-tighter mt-0.5 italic">Avant 11h pour le Lendemain</span>
													</div>
												</div>
											)}
											
											{/* Texte Indisponible */}
											<span class={`status-indisponible text-[10px] font-black uppercase tracking-widest text-cat-pine/40 italic ${isEpuise ? '' : 'hidden'}`}>
												Indisponible
											</span>
										</div>
										
										<button 
											class={`add-to-cart-btn bg-cat-pine text-white w-12 h-12 rounded-2xl flex items-center justify-center hover:bg-cat-teal shadow-lg active:scale-90 transition-all group/btn ${isEpuise ? 'hidden' : ''}`}
											data-id={product.id}
											data-title={product.data.title}
											data-price={product.data.price}
											data-preorder={isPreorder ? "true" : "false"}
											type="button"
										>
											<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover/btn:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4" />
											</svg>
										</button>
									</div>
								</div>
							</div>
						);
					})}
				</div>
				</>
			)}
		</div>
	</section>

	<style is:global>
		/* 1. État de base */
		.variant-btn, .extra-btn, .allergen-btn {
			transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
			cursor: pointer;
			display: inline-flex;
			align-items: center;
			justify-content: center;
		}

		/* 2. Hover */
		.variant-btn:not(.active-variant):hover, 
		.extra-btn:not(.extra-selected):hover, 
		.allergen-btn:not(.allergen-selected):hover {
			transform: scale(1.08) translateY(-3px) !important;
			box-shadow: 0 10px 15px -3px rgba(22, 78, 99, 0.2) !important;
			z-index: 10;
		}

		/* 3. Sélection Variantes & Extras (JAUNE) */
		.active-variant, .extra-selected {
			background-color: #fef08a !important;
			border-color: #164e63 !important;
			border-style: solid !important;
			color: #164e63 !important;
			transform: scale(1.02) !important;
		}

		/* 4. Sélection Allergènes (VERT PINE + TEXTE BLANC) */
		/* On utilise l'attribut class pour être plus fort que Tailwind */
		[class*="allergen-selected"] {
			background-color: #164e63 !important;
			color: #ffffff !important;
			border-style: solid !important;
			border-color: #164e63 !important;
			transform: scale(1.02) !important;
		}

		/* Sécurité ultime pour le texte des allergènes */
		.allergen-btn.allergen-selected,
		.allergen-btn.allergen-selected span {
			color: #ffffff !important;
		}

		/* 5. État non-sélectionné */
		.variant-btn:not(.active-variant),
		.extra-btn:not(.extra-selected),
		.allergen-btn:not(.allergen-selected) {
			background-color: #ffffff !important;
		}

		/* 6. Animation du bouton VOIR PLUS */
		.toggle-description {
			position: relative;
			overflow: hidden;
		}

		.toggle-description:hover {
			color: #164e63 !important; /* Devient Pine au survol */
			transform: translateX(5px) !important; /* Glisse légèrement */
		}

		/* Barre de soulignement animée */
		.toggle-description::after {
			content: '';
			position: absolute;
			bottom: 0;
			left: 0;
			width: 0;
			height: 1px;
			background-color: currentColor;
			transition: width 0.3s ease;
		}

		.toggle-description:hover::after {
			width: 100%;
		}

		/* Style de la barre (Track) */
		.spice-range {
			-webkit-appearance: none;
			appearance: none;
			background: #ffffff !important;
			border: 1px solid rgba(22, 78, 99, 0.1) !important; /* Bordure très fine Pine */
			height: 6px;
			outline: none;
		}

		.spice-range::-webkit-slider-thumb {
			-webkit-appearance: none;
			appearance: none;
			width: 32px;
			height: 32px;
			cursor: pointer;
			/* On utilise une variable CSS avec le piment par défaut */
			background-image: var(--spice-icon, url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><text y='18' font-size='16'>🌿</text></svg>"));
			background-repeat: no-repeat;
			background-position: center;
			background-color: transparent;
			border: none;
			transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		}

		.spice-range::-moz-range-thumb {
			width: 32px;
			height: 32px;
			cursor: pointer;
			background-image: var(--spice-icon, url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><text y='18' font-size='16'>🌿</text></svg>"));
			background-repeat: no-repeat;
			background-position: center;
			border: none;
			transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		}

		/* Animation au survol ou clic */
		.spice-range::-webkit-slider-thumb:hover, 
		.spice-range:active::-webkit-slider-thumb {
			transform: scale(1.3) rotate(-10deg);
		}
	</style>

	<script>
		import { supabase } from '../lib/supabase';
		import {
			attachCategoryFilterHandlers,
			attachGlobalInteractionHandlers,
			getHomePageElements,
			initDescriptionToggles,
			setupModalActions,
			setupLiveStockSync
		} from '../scripts/home';
		document.addEventListener('DOMContentLoaded', () => {
			// --- 1. ÉTAT GLOBAL & OUTILS ---
			let cart = [];
			const targetPhone = "33631541175";

			// Vérifie si l'utilisateur a accepté les cookies
			const hasConsent = () => getCatCookie('catseyes_consent') === 'true';

			const setCatCookie = (name, value, days = 30) => {
				// Verrou RGPD : On n'écrit que si c'est le cookie de consentement OU si consenti
				if (name === 'catseyes_consent' || hasConsent()) {
					const date = new Date();
					date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
					document.cookie = `${name}=${value}; expires=${date.toUTCString()}; path=/; SameSite=Lax`;
				}
			};

			const getCatCookie = (name) => {
				const value = `; ${document.cookie}`;
				const parts = value.split(`; ${name}=`);
				if (parts.length === 2) return parts.pop().split(';').shift();
			};

			// Gestion du type de commande
			const typeBtns = document.querySelectorAll('.order-type-btn');
			typeBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					// 1. On remet tout le monde en "effacé"
					typeBtns.forEach(b => {
						b.classList.remove('active-type', 'opacity-100', 'border-cat-teal');
						b.classList.add('opacity-60', 'text-cat-pine/30');
						b.style.backgroundColor = 'white';
					});
					
					// 2. On active le bouton cliqué (Fond blanc, texte Pine, bordure plus marquée)
					btn.classList.add('active-type', 'opacity-100');
					btn.classList.remove('text-cat-pine/30');
					btn.classList.add('border-cat-pine'); // Ou border-cat-teal si tu veux le distinguer
					
					// On retire l'erreur visuelle si elle était là
					document.getElementById('order-type-title').classList.remove('text-red-500', 'animate-bounce');
				});
			});

			// --- 2. SÉLECTEURS UI ---
			const elements = getHomePageElements();
			let closeAllModals = () => {};

			// --- LOGIQUE DE FILTRAGE ---
			attachCategoryFilterHandlers(elements);

			// --- 3. GESTION DES COOKIES & MÉMOIRE ---
			const hideBanner = () => {
				if (elements.banner) {
					elements.banner.classList.add('opacity-0', 'translate-y-full');
					setTimeout(() => { elements.banner.remove(); }, 500);
				}
			};

			// Action : Accepter
			elements.acceptBtn?.addEventListener('click', () => {
				// 1. On crée le cookie de consentement
				const date = new Date();
				date.setTime(date.getTime() + (30 * 24 * 60 * 60 * 1000));
				document.cookie = `catseyes_consent=true; expires=${date.toUTCString()}; path=/; SameSite=Lax`;
				
				// 2. Maintenant que c'est accepté, on sauvegarde les infos déjà saisies (si besoin)
				updateCartUI(true); 
				hideBanner();
			});

			elements.declineBtn?.addEventListener('click', hideBanner);

			const restoreUserSession = () => {
				// On ne cherche plus savedName ou savedPhone
				
				// On s'assure que les champs sont vides au chargement
				if (elements.clientNameInput) elements.clientNameInput.value = '';
				if (elements.clientPhoneInput) elements.clientPhoneInput.value = '';
				if (elements.lookupPhoneInput) elements.lookupPhoneInput.value = '';

				// On ne restaure QUE le panier
				const savedCart = getCatCookie('ce_cart_items');
				if (savedCart) {
					try {
						cart = JSON.parse(savedCart);
						updateCartUI(false); 
					} catch (e) { console.error("Erreur panier"); }
				}
			};

			// --- 4. LOGIQUE DU PANIER ---
			const updateCartUI = (shouldSave = true) => {
				// Sauvegarde sécurisée (vérifie le consentement via setCatCookie)
				if (shouldSave) {
					setCatCookie('ce_cart_items', JSON.stringify(cart), 1);
				}

				// Mise à jour du badge (nombre d'articles)
				if (elements.cartCountBadge) {
					elements.cartCountBadge.textContent = cart.length.toString();
					cart.length > 0 ? elements.cartCountBadge.classList.remove('hidden') : elements.cartCountBadge.classList.add('hidden');
				}

				// Affichage de la liste des produits
				if (elements.cartItemsList) {
					if (cart.length === 0) {
						elements.cartItemsList.innerHTML = '<p class="text-center opacity-50 italic py-10">Panier vide...</p>';
						elements.totalPrice.textContent = '0.00€';
					} else {
						let total = 0;
						elements.cartItemsList.innerHTML = cart.map((item, index) => {
							total += item.price;
							return `
								<div class="flex justify-between items-center bg-cat-yellow/10 p-4 rounded-2xl border border-cat-pine/5 mb-2">
									<div class="flex-grow pr-4">
										<p class="font-bold text-cat-pine text-sm">${item.title}</p>
										
										<p class="text-[10px] uppercase font-bold text-cat-teal leading-tight">
											${item.variant}
										</p>
										
										${item.allergens && item.allergens.length > 0 
											? `<p class="text-[9px] font-black text-red-400 uppercase mt-1 tracking-tighter">
												❌ SANS : ${item.allergens.join(', ')}
											</p>` 
											: ''
										}
									</div>
									<div class="flex items-center gap-4">
										<span class="font-black text-cat-pine text-sm">${item.price}€</span>
										<button onclick="window.removeFromCart(${index})" class="text-red-400 p-2 hover:scale-110 transition-transform">✕</button>
									</div>
								</div>
							`;
						}).join('');
						elements.totalPrice.textContent = `${total.toFixed(2)}€`;
					}
				}
			};

			// Suppression d'un article
			window.removeFromCart = (index) => {
				cart.splice(index, 1);
				updateCartUI();
			};

			// --- INTERACTIONS GLOBALES (variantes, extras, allergènes, piment) ---
			attachGlobalInteractionHandlers();

			// --- 2. Mise à jour du bouton d'ajout au panier ---
			elements.addToCartBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					const card = btn.closest('.product-card');
					if (!card) return;

					// --- 1. VÉRIFICATION DES SÉLECTIONS OBLIGATOIRES ---
					const variantGroups = card.querySelectorAll('.group-container');
					let allSelected = true;
					let missingGroups = [];

					variantGroups.forEach(group => {
						// On vérifie si un bouton a la classe active-variant dans ce groupe
						const hasSelection = group.querySelector('.variant-btn.active-variant');
						
						if (!hasSelection) {
							allSelected = false;
							const groupName = group.getAttribute('data-group') || "Option";
							missingGroups.push(groupName);
							
							// Feedback visuel : on fait vibrer le titre du groupe (le <p> juste avant la div)
							const groupTitle = group.previousElementSibling;
							if (groupTitle) {
								groupTitle.classList.add('text-red-500', 'animate-bounce');
								setTimeout(() => groupTitle.classList.remove('text-red-500', 'animate-bounce'), 2000);
							}
						}
					});

					// Si une variante manque, on stop tout et on alerte
					if (!allSelected) {
						alert(`Miaou ! Merci de choisir : ${missingGroups.join(', ')} 🐾`);
						return;
					}

					// --- 2. RÉCUPÉRATION DES DONNÉES (Si tout est sélectionné) ---
					
					// Récupération des variantes choisies
					const activeVariants = Array.from(card.querySelectorAll('.variant-btn.active-variant'))
												.map(v => v.textContent.trim());
					
					const variantDisplay = activeVariants.length > 0 ? activeVariants.join(' / ') : "Standard";

					// Récupération des extras
					let extrasPrice = 0;
					const selectedExtras = [];
					card.querySelectorAll('.extra-btn.extra-selected').forEach(extra => {
						const price = parseFloat(extra.getAttribute('data-extra-price') || "0");
						const name = extra.getAttribute('data-extra-name');
						extrasPrice += price;
						selectedExtras.push(name);
					});

					const basePrice = parseFloat(btn.getAttribute('data-price') || "0");
					const baseTitle = btn.getAttribute('data-title');

					// --- RÉCUPÉRATION DU PIMENT (SI ACTIVÉ) ---
					const spiceInput = card.querySelector('.spice-range');
					let spiceInfo = "";
					if (spiceInput) {
						const spiceLabelsShort = ["Pas de Piment", "Doux", "Relevé", "Lave"];
						spiceInfo = ` | Piment : ${spiceLabelsShort[spiceInput.value]}`;
					}

					// --- 3. CRÉATION DE L'OBJET ITEM ---
					const item = {
						title: baseTitle,
						price: basePrice + extrasPrice,
						// On récupère les allergènes (SANS ...)
						allergens: Array.from(card.querySelectorAll('.allergen-btn.allergen-selected') || [])
										.map(a => a.textContent.trim().replace('SANS ', '')), 
						
						// On combine variantes, extras ET l'info piment
						variant: (selectedExtras.length > 0 
							? `${variantDisplay} (+ ${selectedExtras.join(', ')})` 
							: variantDisplay) + spiceInfo,
							
						preorder: btn.getAttribute('data-preorder') === "true"
					};

					// --- 4. ENREGISTREMENT & UI ---
					cart.push(item);
					updateCartUI();

					// --- 5. FEEDBACK BOUTON & RESET EXTRAS ---
					// On désélectionne les extras après l'ajout
					card.querySelectorAll('.extra-btn').forEach(ex => ex.classList.remove('extra-selected'));
					
					// Animation du bouton "+" qui devient "✓"
					const original = btn.innerHTML;
					btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor font-bold"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7" /></svg>`;
					btn.classList.replace('bg-cat-pine', 'bg-cat-teal');
					
					setTimeout(() => { 
						btn.innerHTML = original; 
						btn.classList.replace('bg-cat-teal', 'bg-cat-pine'); 
					}, 800);
				});
			});

			// --- 5. ENVOI COMMANDE ---
			const handleOrder = async (type) => {
				if (cart.length === 0) return;

				// 1. Récupération des données du formulaire
				const form = {
					name: elements.clientNameInput.value,
					phone: elements.clientPhoneInput.value,
					date: document.getElementById('pickup-date').value,
					time: document.getElementById('pickup-time').value,
					note: document.getElementById('client-note').value,
					orderType: document.querySelector('.order-type-btn.active-type')?.getAttribute('data-type') || "À Emporter"
				};

				// 2. Vérification des champs obligatoires
				if (!form.name || !form.phone || !form.date || !form.time) {
					alert("Oups ! Merci de remplir les infos de retrait. 🐾");
					return;
				}

				const selectedTypeBtn = document.querySelector('.order-type-btn.active-type');

				if (!selectedTypeBtn) {
					const typeTitle = document.getElementById('order-type-title');
					if (typeTitle) {
						typeTitle.classList.add('text-red-500', 'animate-bounce');
						setTimeout(() => typeTitle.classList.remove('text-red-500', 'animate-bounce'), 2000);
					}
					alert("Miaou ! N'oubliez pas de choisir : Sur Place ou À Emporter. 🐾");
					
					// On scroll vers le haut pour montrer l'erreur
					const modalContainer = document.querySelector('#cart-modal .overflow-y-auto');
					modalContainer?.scrollTo({ top: 0, behavior: 'smooth' });
					return;
				}

				// Si on arrive ici, c'est que le type est choisi, on l'ajoute à l'objet form
				form.orderType = selectedTypeBtn.getAttribute('data-type');

				// --- LOGIQUE DE VALIDATION TEMPORELLE ---
				const now = new Date();
				const currentHour = now.getHours();

				// On récupère la date du formulaire sans les problèmes de fuseau horaire
				// L'input date renvoie "YYYY-MM-DD"
				const dateValue = document.getElementById('pickup-date').value; 
				const todayStr = now.toISOString().split('T')[0]; // Format "YYYY-MM-DD"

				// Sécurité Globale : Pas de commande dans le passé (Date + Heure)
				const [hours, minutes] = form.time.split(':');
				const pickupFullDate = new Date(form.date + 'T' + form.time); // Force l'heure locale

				if (pickupFullDate.getTime() <= now.getTime()) {
					alert("Miaou ! Le créneau choisi est déjà passé. 🐾");
					return;
				}

				// Jours de fermeture (On recréé la date proprement pour le getDay)
				const selectedDate = new Date(form.date + 'T00:00:00');
				if (selectedDate.getDay() === 0 || selectedDate.getDay() === 1) {
					alert("Le restaurant est fermé le dimanche et le lundi. 🐾");
					return;
				}

				// Plage horaire globale
				if (form.time < "11:30" || form.time > "19:00") {
					alert("Les retraits se font uniquement entre 11h30 et 19h00. 🐾");
					return;
				}

				// Détection des plats "Sur Réservation"
				const hasPreorderItem = cart.some(item => item.preorder === true);

				if (hasPreorderItem) {
					const isToday = (dateValue === todayStr);

					// RÈGLE 1 : Si c'est aujourd'hui et qu'on a dépassé 11h
					if (isToday && currentHour >= 11) {
						// --- CALCUL DU PROCHAIN JOUR DISPONIBLE ---
						let nextAvailableDate = new Date(now);
						nextAvailableDate.setDate(now.getDate() + 1); // On commence par viser demain

						// Si demain est Dimanche (0) ou Lundi (1), on décale jusqu'à Mardi (2)
						while (nextAvailableDate.getDay() === 0 || nextAvailableDate.getDay() === 1) {
							nextAvailableDate.setDate(nextAvailableDate.getDate() + 1);
						}

						// Formatage de la date pour le message (ex: "mardi 28 avril")
						const dateOptions = { weekday: 'long', day: 'numeric', month: 'long' };
						const dateFriendly = nextAvailableDate.toLocaleDateString('fr-FR', dateOptions);

						alert(`Votre panier contient des plats sur réservation. Le retrait n'est possible qu'à partir du ${dateFriendly} à 13h00. 🐾`);
						return;
					}
					
					// RÈGLE 2 : Heure min pour les réservations (Toujours 13h)
					if (form.time < "13:00") {
						alert("Les plats sur réservation ne sont disponibles qu'à partir de 13h00. 🐾");
						return;
					}
				}

				// 3. Préparation du Modal de Confirmation
				const total = cart.reduce((sum, item) => sum + item.price, 0);
				
				// Remplissage dynamique du modal
				elements.confirmDetails.innerHTML = `
					<p>Confirmer la commande pour <span class="font-black text-cat-teal">${form.name}</span> ?</p>
					<p class="text-lg font-black text-cat-pine">Total : ${total.toFixed(2)}€</p>
					<p class="text-[10px] mt-4 italic">Envoyez le message pour que l'équipe Cat's Eyes valide la préparation.</p>
				`;

				// Reset de l'affichage du modal
				elements.confirmModal.classList.remove('hidden');
				elements.smsFallback.classList.add('hidden');
				elements.finalWhatsappBtn.classList.remove('hidden');
				elements.noWhatsappBtn.classList.remove('hidden');
				elements.confirmAltBtn.classList.add('hidden');

				// --- GESTION DES CLICS DANS LE MODAL ---

				// A. Action Finale (Enregistrement + WhatsApp)
				elements.finalWhatsappBtn.onclick = async () => {
					try {
						await supabase.from('commandes').insert([{
							nom_client: form.name, 
							telephone: form.phone, 
							date_retrait: form.date,
							heure_retrait: form.time, 
							items: cart, 
							total: total, 
							note: form.note, 
							statut: 'nouveau'
						}]);
					} catch (err) { console.error("Erreur Supabase:", err); }

					const dateFr = form.date.split('-').reverse().join('/');
					let msg = `*NOUVELLE COMMANDE - CAT'S EYES*\nClient: ${form.name}\nRetrait: ${dateFr} à ${form.time}\n\n--- ARTICLES ---\n`;
					
					cart.forEach(i => {
						msg += `- ${i.title} [${i.variant}] : ${i.price}€\n`;
						
						// On ajoute les allergènes sélectionnés s'il y en a
						if (i.allergens && i.allergens.length > 0) {
							msg += `  ⚠️ ALLERGIES : ${i.allergens.join(', ')}\n`;
						}
					});
					
					msg += `\n*TOTAL : ${total.toFixed(2)}€*`;
					if(form.note) msg += `\nNote: ${form.note}`;

					window.open(`https://wa.me/33631541175?text=${encodeURIComponent(msg)}`, '_blank');

					finalizeOrder();
					alert("Commande transmise ! Pensez à envoyer le message WhatsApp qui vient de s'ouvrir. 🐾");
				};

				// B. Option "Je n'ai pas WhatsApp"
				elements.noWhatsappBtn.onclick = () => {
					elements.smsFallback.classList.remove('hidden');
					// AJOUTE CETTE LIGNE CI-DESSOUS :
					elements.confirmAltBtn.classList.remove('hidden'); 
					
					elements.noWhatsappBtn.classList.add('hidden');
					elements.finalWhatsappBtn.classList.add('hidden');
				};

				// C. Action Alternative (Enregistrement seul)
				elements.confirmAltBtn.onclick = async () => {
					try {
						await supabase.from('commandes').insert([{
							nom_client: form.name, telephone: form.phone, date_retrait: form.date,
							heure_retrait: form.time, items: cart, total: total, note: form.note, statut: 'nouveau'
						}]);
					} catch (err) { console.error("Erreur Supabase:", err); }

					finalizeOrder();
					alert("Commande enregistrée ! L'équipe Cat's Eyes attend votre appel ou SMS pour valider. 🐾");
				};

				// D. Annuler
				elements.cancelBtn.onclick = () => elements.confirmModal.classList.add('hidden');

				// Fonction interne pour nettoyer après commande
				function finalizeOrder() {
					cart = [];
					updateCartUI();
					elements.confirmModal.classList.add('hidden');
					closeAllModals();
				}
			};

			// --- 6. FIDÉLITÉ ---
			elements.checkLoyaltyBtn?.addEventListener('click', async () => {
				const phone = elements.lookupPhoneInput?.value.trim().replace(/\s+/g, '');
				
				if (!phone) {
					alert("Miaou ! Il manque le numéro pour trouver vos points. 🐾");
					return;
				}

				// 2. Accès rapide Admin
				if (phone === "0631541175" || phone === targetPhone) {
					window.location.href = '/admin/login';
					return;
				}

				elements.checkLoyaltyBtn.textContent = "Recherche...";
				
				try {
					// 3. Appel Supabase
					const { data, error } = await supabase
						.from('profils')
						.select('*')
						.eq('telephone', phone)
						.single();

					if (error || !data) {
						alert("Numéro non trouvé. Passez nous voir au restaurant pour commencer à cumuler ! 🐾");
					} else {
						// 4. Calcul de la progression (Palier de 10 points)
						const points = data.points_fidelite || 0;
						const goal = 10;
						const progress = Math.min((points / goal) * 100, 100);
						const remaining = Math.max(goal - points, 0);

						// 5. Mise à jour de l'UI
						const userPointsEl = document.getElementById('user-points');
						const pointsBarEl = document.getElementById('points-bar');
						const pointsNeededEl = document.getElementById('points-needed');

						if (userPointsEl) userPointsEl.textContent = points.toString();
						if (pointsBarEl) pointsBarEl.style.width = `${progress}%`;
						if (pointsNeededEl) pointsNeededEl.textContent = remaining.toString();

						// 6. Switch d'affichage (cache le formulaire, montre les stats)
						document.getElementById('profile-login')?.classList.add('hidden');
						document.getElementById('profile-stats')?.classList.remove('hidden');
					}
				} catch (err) {
					console.error("Erreur Fidélité:", err);
					alert("Oups, une petite erreur de connexion... 🐾");
				} finally {
					elements.checkLoyaltyBtn.textContent = "Voir mes points";
				}

				const changePhoneBtn = document.getElementById('change-phone-btn');
				changePhoneBtn?.addEventListener('click', () => {
					// 1. On vide le champ de saisie pour repartir à neuf
					if (elements.lookupPhoneInput) elements.lookupPhoneInput.value = '';
					
					// 2. On bascule l'affichage
					document.getElementById('profile-stats')?.classList.add('hidden');
					document.getElementById('profile-login')?.classList.remove('hidden');
					
					// 3. Optionnel : On remet le bouton de recherche à son texte initial
					if (elements.checkLoyaltyBtn) elements.checkLoyaltyBtn.textContent = "Voir mes points";
				});
			});

			// --- GESTION DU "VOIR PLUS" DYNAMIQUE ---
			initDescriptionToggles();

			// --- MODALS / ACTIONS / STOCK LIVE ---
			closeAllModals = setupModalActions(elements, updateCartUI, handleOrder).closeAllModals;
			const stockChannel = setupLiveStockSync(supabase);

			// --- INITIALISATION ---
			if (!getCatCookie('catseyes_consent') && elements.banner) {
				setTimeout(() => { elements.banner?.classList.replace('hidden', 'block'); }, 600);
			}

			restoreUserSession();
			setTimeout(initDescriptionToggles, 100);
		});
	</script>

